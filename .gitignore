# Exclude large checkpoint files
checkpoints/
*.pth
*.pt

# Exclude logs
logs/
*.log
*.out
*.err
training.log

# Exclude virtual environment
pangenome/
venv/
env/

# Exclude cache
__pycache__/
*.pyc
*.pyo

# Exclude temporary files
*.tmp
*.swp
*~

# Input and generated data
data/

# Results
results/

# Tokenizer (if large)
# pangenome_gpt_tokenizer.json

# Hyperparam search trial artifacts
logs/hyperparam_search_*/

# Keep folder structure
!data/.gitkeep
!logs/.gitkeep
!checkpoints/.gitkeep
!results/.gitkeep
